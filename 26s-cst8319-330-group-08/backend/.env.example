# HomeBoost backend environment
PORT=5000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=project2
DB_CONNECTION_LIMIT=10

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# CORS
# Comma-separated frontend origins allowed to call the API.
# Local example:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production example:
# CORS_ORIGINS=https://homeboost-test.vercel.app
# FRONTEND_URL=https://homeboost-test.vercel.app

# Optional dev/preview allowances
ALLOW_VERCEL_PREVIEWS=false
ALLOW_CODESPACES_ORIGINS=false
